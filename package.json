{
  "name": "node-30days",
  "version": "1.0.0",
  "description": "Day1",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run ",
    "check:env:dev": "node --env-file=.env.development src/day1/check-env.js",
    "check:env:staging": "node --env-file=.env.staging src/day1/check-env.js",
    "check:env:prod": "node --env-file=.env.production src/day1/check-env.js",
    "predev": "pnpm run check:env:dev",
    "prestaging": "pnpm run check:env:staging",
    "preprod": "pnpm run check:env:prod",
    "dev": "node --env-file=.env.development --watch src/day1/index.js",
    "staging": "node --env-file=.env.staging src/day1/index.js",
    "prod": "node --env-file=.env.production src/day1/index.js",

    "day2:ping": "node src/day2/scripts/ping-urls.js",

    "build": "echo 'Sẽ thêm build TS vào ngày 6' && exit 0",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.3"
  },
  "lint-staged": {
    "src/**/*.js": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
